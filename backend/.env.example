APP_ENV=local
DATABASE_URL=mysql+pymysql://user:password@127.0.0.1:3306/education_service
DIFY_API_BASE_URL=http://127.0.0.1:5001
DIFY_API_KEY=replace_with_local_key
# 本地无 Dify 环境可保持 true；真实联调时改为 false 并配置 DIFY_API_KEY
DIFY_MOCK_ENABLED=true
REPORT_EXPORT_DIR=storage/reports
# PDF 已改为后端 HTML 模板直接生成；该变量仅保留兼容旧配置
REPORT_PDF_CONVERTER_PATH=
